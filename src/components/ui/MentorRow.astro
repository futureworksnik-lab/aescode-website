---
/**
 * @component MentorRow
 * @description Renders a research mentor row with photo, name, specialty, and bio.
 * @example
 * <MentorRow index="M1" role="Mentor" name="Dr. Y" title="Researcher" specialty="AI" bio="..." photo="/img.jpg" />
 */
interface Props {
  index: string;
  role: string;
  name: string;
  title: string;
  specialty: string;
  bio: string[];
  photo: string;
}
const { index, role, name, title, specialty, bio, photo } = Astro.props;
---

<div class="mentor-row">
  <div class="mentor-row__photo">
    <img src={photo} alt={name} loading="lazy" decoding="async">
  </div>
  <div class="mentor-row__body">
    <span class="mentor-row__index">{index} / {role}</span>
    <div class="mentor-row__header">
      <h4 class="mentor-row__name">{name}</h4>
      <span class="mentor-row__specialty">{specialty}</span>
    </div>
    <span class="mentor-row__title">{title}</span>
    {bio.map((p) => <p class="mentor-row__bio">{p}</p>)}
  </div>
</div>

<style>
  .mentor-row {
    display: flex;
    gap: 2.5rem;
    border-top: var(--border-hairline) solid var(--outline-variant);
    padding: 2.5rem 0;
  }
  .mentor-row__photo {
    flex-shrink: 0;
    width: 120px;
    height: 150px;
  }
  .mentor-row__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 2px;
    filter: grayscale(1) contrast(1.1);
    transition: filter 0.5s ease;
  }
  .mentor-row__photo img:hover {
    filter: grayscale(0) contrast(1);
  }
  .mentor-row__body {
    flex: 1;
  }
  .mentor-row__index {
    font-family: var(--font-sans);
    font-size: var(--font-size-micro);
    text-transform: uppercase;
    color: var(--outline-variant);
    display: block;
    margin-bottom: 0.5rem;
  }
  .mentor-row__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.25rem;
  }
  .mentor-row__name {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--primary);
    font-weight: 400;
  }
  .mentor-row__specialty {
    font-family: var(--font-sans);
    font-size: var(--font-size-mini);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--outline-variant);
  }
  .mentor-row__title {
    font-family: var(--font-sans);
    font-size: var(--font-size-mini);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--secondary);
    display: block;
    margin-bottom: 1rem;
  }
  .mentor-row__bio {
    font-family: var(--font-sans);
    font-size: var(--font-size-body-sm-alt);
    color: var(--secondary);
    line-height: 1.6;
    max-width: 560px;
  }
  @media (max-width: 768px) {
    .mentor-row {
      flex-direction: column;
      gap: 1.5rem;
    }
    .mentor-row__header {
      flex-direction: column;
      gap: 0.375rem;
    }
  }
</style>
