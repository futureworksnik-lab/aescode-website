---
// Hero.astro — AesCode Co. v2.0
// Split layout: text 60% / visual 40%
---

<section class="hero section-hero" id="hero" aria-labelledby="hero-heading">
  <div class="container hero__grid">

    <!-- Left: Text content -->
    <div class="hero__content">
      <p class="label-sm data-sm mb-lg reveal" style="color: var(--accent);">
        MEDTECH RESEARCH PLATFORM · FOUNDED 2026
      </p>

      <h1 id="hero-heading" class="display-hero serif italic text-primary mb-xl reveal reveal--delay-1">
        India's Clinical AI<br />Validation Infrastructure.
      </h1>

      <p class="body-lg text-on-surface mb-2xl reveal reveal--delay-2" style="max-width: 36rem; color: var(--on-surface-variant);">
        Connecting engineering teams to real clinical problems, training AI on hospital data without moving it, and certifying the tools hospitals can trust.
      </p>

      <div class="hero__ctas reveal reveal--delay-3">
        <a href="/cohort1" class="btn btn--primary" id="hero-cta-primary">
          Explore Cohort 1
        </a>
        <a href="/contact" class="btn btn--secondary" id="hero-cta-secondary">
          Partner With Us
        </a>
      </div>

      <div class="hero__meta reveal reveal--delay-4">
        <div class="hero__meta-item">
          <span class="data-lg mono text-primary" data-counter data-target="250" data-suffix="+">250+</span>
          <span class="label-sm" style="margin-top: 0.25rem;">Research Abstracts</span>
        </div>
        <div class="hero__meta-divider"></div>
        <div class="hero__meta-item">
          <span class="data-lg mono text-primary" data-counter data-target="20">20</span>
          <span class="label-sm" style="margin-top: 0.25rem;">Finalist Teams</span>
        </div>
        <div class="hero__meta-divider"></div>
        <div class="hero__meta-item">
          <span class="data-lg mono text-primary" data-counter data-target="5">5</span>
          <span class="label-sm" style="margin-top: 0.25rem;">Clinical Problems</span>
        </div>
      </div>
    </div>

    <!-- Right: Visual -->
    <div class="hero__visual reveal reveal--delay-2">
      <div class="hero__visual-frame">
        <img
          src="/images/archive/event_01.jpeg"
          alt="AesCode Cohort 1 — participants working on clinical AI problems at Bharati Vidyapeeth Medical College"
          class="hero__photo"
          width="640"
          height="800"
          loading="eager"
        />
        <div class="hero__visual-caption">
          <span class="mono data-sm" style="color: rgba(255,255,255,0.6);">COHORT 01 · BHARATI VIDYAPEETH · 2026</span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    padding-top: calc(68px + var(--space-6xl));
    padding-bottom: var(--space-5xl);
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 60fr 40fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  /* CTA group */
  .hero__ctas {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  /* Quick stats below CTAs */
  .hero__meta {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2xl);
    margin-top: var(--space-3xl);
    padding-top: var(--space-2xl);
    border-top: 0.5px solid rgba(196, 198, 206, 0.4);
  }
  .hero__meta-item {
    display: flex;
    flex-direction: column;
  }
  .hero__meta-divider {
    width: 0.5px;
    align-self: stretch;
    background: rgba(196, 198, 206, 0.4);
  }

  /* Right visual */
  .hero__visual {
    position: relative;
  }
  .hero__visual-frame {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--surface-container);
  }
  .hero__visual-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 50%,
      rgba(2, 25, 52, 0.65) 100%
    );
    z-index: 1;
  }
  .hero__photo {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: grayscale(15%) contrast(1.05);
  }
  .hero__visual-caption {
    position: absolute;
    bottom: var(--space-lg);
    left: var(--space-lg);
    right: var(--space-lg);
    z-index: 2;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero__grid {
      grid-template-columns: 1fr;
      gap: var(--space-3xl);
    }
    .hero__visual { order: -1; }
    .hero__photo { aspect-ratio: 16 / 7; object-position: center 30%; }
  }
  @media (max-width: 768px) {
    .hero {
      padding-top: calc(68px + var(--space-4xl));
      padding-bottom: var(--space-4xl);
    }
    .hero__meta { gap: var(--space-xl); }
    .hero__ctas { flex-direction: column; align-items: stretch; }
    .hero__ctas .btn { justify-content: center; }
  }
  @media (max-width: 480px) {
    .hero__photo { aspect-ratio: 4 / 3; }
  }
</style>
