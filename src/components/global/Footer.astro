---
/**
 * @component Footer
 * @description Global site footer with brand info, legal links, social links, and ABDM compliance note.
 * @example
 * <Footer />
 */
// No props — fully self-contained
import footerData from '../../data/footer.json';
---

<footer class="footer" role="contentinfo">
  <div class="footer__grid">
    <div class="footer__brand">
      <div class="footer__brand-obj">{footerData.brand}</div>
      <p class="footer__tagline">{footerData.tagline}</p>
      {footerData.abdmNote && (
        <p class="footer__abdm-note">{footerData.abdmNote}</p>
      )}
    </div>
    <div class="footer__legal">
      <h4 class="footer__label">{footerData.legal.label}</h4>
      <ul class="footer__links">
        {footerData.legal.links.map((link) => (
          <li><a href={link.href} class="footer__link">{link.label}</a></li>
        ))}
      </ul>
    </div>
    <div class="footer__connect">
      <h4 class="footer__label">{footerData.connect.label}</h4>
      <ul class="footer__links">
        {footerData.connect.links.map((link) => (
          <li><a href={link.href} class="footer__link">{link.label}</a></li>
        ))}
      </ul>
      <div class="footer__meta">
        <span>{footerData.copyright}</span>
        <span>{footerData.version}</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--surface);
    padding: 5rem 0 3rem;
    margin-top: auto;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    width: 100%;
    max-width: var(--max-width);
    margin-left: auto;
    margin-right: auto;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  /* Col 1-4: Brand */
  .footer__brand {
    grid-column: span 1;
  }

  .footer__brand-obj {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--primary);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .footer__tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1rem;
    color: var(--secondary);
  }

  .footer__abdm-note {
    font-family: var(--font-sans);
    font-size: var(--label-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--secondary);
    margin-top: 0.75rem;
    opacity: 0.7;
  }

  /* Col 5-8: Legal */
  .footer__legal {
    grid-column: span 1;
  }

  /* Col 9-12: Connect */
  .footer__connect {
    grid-column: span 1;
    display: flex;
    flex-direction: column;
  }

  .footer__label {
    font-family: var(--font-sans);
    font-size: var(--label-md);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--on-surface);
    margin-bottom: 1rem;
  }

  .footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer__link {
    font-family: var(--font-sans);
    font-size: var(--label-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__link:hover {
    color: var(--primary);
  }

  .footer__meta {
    font-family: var(--font-sans);
    font-size: var(--label-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--secondary);
    margin-top: 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer__social {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .footer__social-link {
    color: var(--secondary);
    transition: color var(--transition-fast);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer__social-link:hover {
    color: var(--primary);
  }

  .footer__social-icon {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  /* Media query for tablet + desktop grid */
  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: repeat(12, 1fr);
      gap: 2rem;
    }

    .footer__brand {
      grid-column: span 4;
    }

    .footer__legal {
      grid-column: span 4;
    }

    .footer__connect {
      grid-column: span 4;
    }
  }

  /* Mobile override */
  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr !important;
      gap: 3rem !important;
    }
  }
</style>
