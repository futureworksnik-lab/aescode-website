---
/**
 * @component HeroSection
 * @description Reusable page hero with label, title, subtitle, optional version tag, and slotted content.
 * @example
 * <HeroSection label="ABOUT" title="The Origin." subtitle="Our story." />
 */
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  versionTag?: string;
  titleSize?: string;
  padding?: string;
}

const {
  label,
  title,
  subtitle,
  versionTag,
  titleSize = 'clamp(3.5rem, 10vw, 7rem)',
  padding = '6rem 0 4rem',
} = Astro.props;
---

<section style={`padding: ${padding};`}>
  <div class="container">
    <div style="max-width: 56rem;">
      {label && (
        <p class="label-md" style="margin-bottom: 2rem; color: var(--secondary);">{label}</p>
      )}
      <h1 style={`font-style: italic; font-size: ${titleSize}; line-height: 1.05; margin-bottom: 2.5rem;`}>
        {title}
      </h1>
      {subtitle && (
        <p style="font-size: 1.25rem; line-height: 1.6; max-width: 48rem; color: var(--on-surface);">
          {subtitle}
        </p>
      )}
      {versionTag && (
        <div style="margin-top: 5rem;">
          <div style="width: 100%; height: 0.5px; background-color: var(--outline-variant); margin-bottom: 1rem;"></div>
          <p class="label-sm" style="color: var(--secondary); letter-spacing: 0.15em;">{versionTag}</p>
        </div>
      )}
      <slot />
    </div>
  </div>
</section>
