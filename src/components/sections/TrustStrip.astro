---
/**
 * TrustStrip.astro
 * A horizontal credibility strip placed immediately below the hero section.
 * Uses --primary background with white text for maximum contrast.
 *
 * Props:
 *   items: Array<{ stat: string; subtext: string }> — Three trust signal columns
 */
interface Props {
  items: Array<{ stat: string; subtext: string }>;
}

const { items } = Astro.props;
---

<section class="trust-strip animate-on-scroll">
  <div class="container">
    <div class="trust-strip__grid">
      {items.map((item) => (
        <div class="trust-strip__col">
          <p class="trust-strip__stat">{item.stat}</p>
          <p class="trust-strip__subtext">{item.subtext}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-strip {
    background-color: var(--primary);
    padding: 3rem 0;
  }

  .trust-strip__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .trust-strip__col {
    text-align: center;
  }

  .trust-strip__col:not(:last-child) {
    border-right: 0.5px solid rgba(255, 255, 255, 0.15);
  }

  .trust-strip__stat {
    font-family: var(--font-serif);
    font-size: var(--headline-sm);
    color: var(--on-primary);
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  .trust-strip__subtext {
    font-family: var(--font-sans);
    font-size: var(--label-sm);
    color: var(--on-primary);
    opacity: 0.7;
    letter-spacing: 0.02em;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .trust-strip__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .trust-strip__col:not(:last-child) {
      border-right: none;
      border-bottom: 0.5px solid rgba(255, 255, 255, 0.15);
      padding-bottom: 2rem;
    }
  }
</style>
