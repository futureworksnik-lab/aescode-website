---
/**
 * @component Newsletter
 * @description Full-width newsletter signup section with Supabase-backed email capture.
 * @example
 * <Newsletter headline="Research updates, directly to your inbox." />
 */
interface Props {
  headline?: string;
  subtext?: string;
  benefits?: string[];
  socialProof?: string;
  source?: string;
}

const {
  headline = 'Research updates, directly to your inbox.',
  subtext = 'Weekly dispatches on MedTech research, cohort updates, and institutional announcements.',
  benefits = [
    'Cohort 2 problem statements and application windows',
    'Clinical AI research dispatches — India-specific, weekly',
    'Institutional partnership announcements',
  ],
  socialProof = 'Join 400+ researchers and engineers',
  source = 'home',
} = Astro.props;
---

<section class="newsletter-section">
  <div class="container">
    <div class="newsletter-section__content">
      <span class="newsletter-section__label">STAY INFORMED</span>
      <h2 class="newsletter-section__headline">{headline}</h2>
      <p class="newsletter-section__subcopy">{subtext}</p>
      {benefits.length > 0 && (
        <ul class="newsletter-section__benefits">
          {benefits.map((b) => (
            <li>{b}</li>
          ))}
        </ul>
      )}
      <p class="newsletter-section__social-proof">{socialProof}</p>
      <form class="newsletter-section__form" novalidate id="newsletter-form">
        <div class="newsletter-section__input-wrapper">
          <input type="email" class="newsletter-section__input" placeholder="Email address" required>
        </div>
        <button type="submit" class="btn-primary" style="min-width: 160px;">SUBSCRIBE</button>
      </form>
    </div>
  </div>
</section>

<script>
  // --- Newsletter Supabase Handler ---
  let supabaseClient: any = null;
  async function getSupabase() {
    if (!supabaseClient) {
      const { createClient } = await import('@supabase/supabase-js');
      supabaseClient = createClient(
        import.meta.env.PUBLIC_SUPABASE_URL,
        import.meta.env.PUBLIC_SUPABASE_ANON_KEY
      );
    }
    return supabaseClient;
  }

  const form = document.getElementById('newsletter-form');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const emailInput = form.querySelector('.newsletter-section__input') as HTMLInputElement;
    const submitBtn = form.querySelector('.btn-primary') as HTMLButtonElement;
    const email = emailInput.value.trim();
    const inputWrapper = form.querySelector('.newsletter-section__input-wrapper')!;

    // Clear previous error
    const existingError = form.querySelector('.newsletter-section__error');
    if (existingError) existingError.remove();
    submitBtn.classList.remove('btn-message');

    // Validate
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!email || !emailRegex.test(email)) {
      const span = document.createElement('span');
      span.className = 'newsletter-section__error';
      span.style.color = 'var(--error)';
      span.style.fontFamily = 'var(--font-sans)';
      span.style.fontSize = 'var(--label-sm)';
      span.style.marginTop = '4px';
      span.textContent = 'Please enter a valid email.';
      inputWrapper.appendChild(span);
      return;
    }

    submitBtn.disabled = true;
    emailInput.disabled = true;

    try {
      const supabase = await getSupabase();
      const { error } = await supabase
        .from('newsletter_subscribers')
        .insert([{ email, source: 'home', created_at: new Date().toISOString() }]);

      if (error) {
        if (error.code === '23505' || error.message.toLowerCase().includes('unique')) {
          submitBtn.textContent = "You're already subscribed.";
        } else {
          submitBtn.textContent = "Something went wrong. Try again.";
        }
        submitBtn.style.textTransform = 'none';
        submitBtn.classList.add('btn-message');
        emailInput.disabled = false;
      } else {
        submitBtn.textContent = "You're on the list.";
        submitBtn.style.textTransform = 'none';
        submitBtn.classList.add('btn-message');
      }
    } catch {
      submitBtn.textContent = "Something went wrong. Try again.";
      submitBtn.style.textTransform = 'none';
      submitBtn.classList.add('btn-message');
      emailInput.disabled = false;
    }
  });

  // Reset on input change
  document.querySelectorAll('.newsletter-section__input').forEach(input => {
    input.addEventListener('input', (e) => {
      const form = (e.target as HTMLElement).closest('.newsletter-section__form')!;
      const btn = form.querySelector('.btn-primary') as HTMLButtonElement;
      const err = form.querySelector('.newsletter-section__error');
      if (err) err.remove();
      if (btn.classList.contains('btn-message')) {
        btn.classList.remove('btn-message', 'error');
        btn.textContent = 'SUBSCRIBE';
        btn.style.textTransform = '';
        btn.disabled = false;
      }
      if ((e.target as HTMLInputElement).disabled) {
        (e.target as HTMLInputElement).disabled = false;
      }
    });
  });
</script>

<style>
  .newsletter-section {
    padding: 6rem 0;
    background-color: var(--surface);
    width: 100%;
  }

  .newsletter-section__content {
    max-width: 40rem;
  }

  .newsletter-section__label {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--label-md);
    color: var(--secondary);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
  }

  .newsletter-section__headline {
    font-family: var(--font-serif);
    font-size: var(--display-md);
    color: var(--primary);
    margin-bottom: var(--space-md);
    line-height: 1.2;
  }

  .newsletter-section__subcopy {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    color: var(--on-surface-variant);
    margin-bottom: var(--space-xl);
    line-height: 1.6;
  }

  .newsletter-section__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .newsletter-section__input-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    width: 100%;
  }

  .newsletter-section__input {
    font-family: var(--font-sans);
    font-size: var(--body-lg);
    color: var(--on-surface);
    background: transparent;
    border: none;
    border-bottom: var(--border-hairline) solid var(--outline-variant);
    padding: 0.75rem 0;
    transition: border-color var(--transition-fast), border-width var(--transition-fast);
  }

  .newsletter-section__input::placeholder {
    color: var(--secondary);
  }

  .newsletter-section__input:focus {
    outline: none;
    border-bottom: 1.5px solid var(--primary);
    margin-bottom: -1px;
  }

  .newsletter-section__benefits {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-md) 0;
  }

  .newsletter-section__benefits li {
    font-family: var(--font-sans);
    font-size: var(--body-md);
    color: var(--on-surface-variant);
    line-height: 1.8;
    padding-left: 1.25rem;
    position: relative;
  }

  .newsletter-section__benefits li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--primary);
    font-size: var(--body-sm);
  }

  .newsletter-section__social-proof {
    font-family: var(--font-sans);
    font-size: var(--label-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-bottom: var(--space-xl);
  }

  @media (min-width: 768px) {
    .newsletter-section__form {
      flex-direction: row;
      align-items: flex-end;
      justify-content: flex-start;
    }
    .newsletter-section__input-wrapper {
      flex: none;
      width: 100%;
      max-width: 360px;
    }
  }

  @media (max-width: 767px) {
    .newsletter-section__input {
      border-top: none !important;
      border-left: none !important;
      border-right: none !important;
      border-radius: 0 !important;
      padding: 0.75rem 0;
    }
  }
</style>
