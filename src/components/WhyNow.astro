---
// WhyNow.astro — AesCode Co. v2.0
// Three Convergences — numbered ghost-border card grid
const convergences = [
  {
    num: '01',
    heading: 'Infrastructure is ready.',
    body: 'ABDM reached 834 million citizens in 2025. India\'s National Federated Learning Platform MoU was signed in October 2024. The rails exist. The application layer is missing.',
    badge: 'ABDM · NFLP 2024',
  },
  {
    num: '02',
    heading: 'Regulation is hardening.',
    body: 'CDSCO is drafting SaMD regulations. ICMR published AI ethics guidelines in 2023. Draft DPDP rules were released January 2025. Every clinical AI tool will eventually require validation. First-mover in certification becomes institutional moat.',
    badge: 'CDSCO · ICMR · DPDP',
  },
  {
    num: '03',
    heading: 'Hospitals are ready — but only for certified tools.',
    body: 'Apollo deployed 20 certified AI tools in 2024. The Indian hospital market is not waiting for AI. It is waiting for trusted AI. That is the bottleneck Aescode resolves.',
    badge: 'MARKET READINESS',
  },
];
---

<section class="why-now section-primary" id="why-now" aria-labelledby="why-now-heading">
  <div class="container">
    <div class="why-now__header reveal">
      <p class="label-sm mb-md" style="color: var(--accent);">THE TIMING</p>
      <h2 id="why-now-heading" class="display-md serif italic text-primary mb-sm">
        Three things converged at once.
      </h2>
    </div>

    <div class="why-now__grid">
      {convergences.map((item, i) => (
        <article class={`card card--ghost card--hover why-now__card reveal reveal--delay-${i + 1}`}>
          <div class="why-now__num-row">
            <span class="why-now__num mono data-md text-accent">{item.num}</span>
            <span class="badge">{item.badge}</span>
          </div>
          <h3 class="headline-sm serif text-primary mb-md">{item.heading}</h3>
          <p class="body-sm" style="color: var(--on-surface-variant);">{item.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .why-now__header { margin-bottom: var(--space-3xl); }

  .why-now__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .why-now__card { padding: var(--space-2xl); }

  .why-now__num-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-xl);
  }
  .why-now__num {
    font-size: 2.5rem;
    line-height: 1;
    font-weight: 500;
    opacity: 0.85;
  }

  .headline-sm { font-size: var(--headline-sm); line-height: 1.3; font-weight: 600; }

  @media (max-width: 1024px) {
    .why-now__grid { grid-template-columns: 1fr; gap: var(--space-md); }
    .why-now__card { display: grid; grid-template-columns: auto 1fr; gap: var(--space-lg); align-items: start; }
    .why-now__num-row { flex-direction: column; align-items: flex-start; gap: var(--space-sm); }
  }
  @media (max-width: 768px) {
    .why-now__card { display: flex; flex-direction: column; }
  }
</style>
