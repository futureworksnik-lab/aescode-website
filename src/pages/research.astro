---
/**
 * research.astro
 * Filterable grid of research briefs from research-briefs.json.
 * Cards show title, date, tags, and a "Read" link.
 * Filter bar by sourceType and tag.
 * 
 * This page becomes the home for the 250+ Cohort 1 abstracts once catalogued.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import { getCollection } from 'astro:content';

// Content Collections query — shape-preserving transform
const abstractEntries = await getCollection('abstracts');
const researchData = { briefs: abstractEntries.map(e => e.data) };

const allTags = [...new Set(researchData.briefs.flatMap(b => b.tags))].sort();
const sourceTypes = [...new Set(researchData.briefs.map(b => b.sourceType))].sort();

const sourceTypeLabels: Record<string, string> = {
  cohort_abstract: 'Cohort Abstract',
  deep_research: 'Deep Research',
  autoresearch: 'AutoResearch',
  co_authored_paper: 'Co-Authored Paper',
};
---

<BaseLayout
  title="Research — Aescode Co. Clinical AI Research Briefs"
  description="Browse Aescode Co.'s research briefs: Cohort 1 abstracts, deep research, and clinical AI publications. Filterable by source type and topic."
  keywords="clinical AI research, MedTech research briefs, Cohort 1 abstracts, healthcare AI papers, federated learning research"
>
  <!-- Hero -->
  <HeroSection
    label="RESEARCH ARCHIVE"
    title="Research Briefs."
    subtitle="Browse structured research outputs from Aescode cohorts, deep research initiatives, and collaborative publications."
    padding="6rem 0 3rem"
  />

  <!-- Filter Bar -->
  <section class="research-filter-section">
    <div class="container">
      <div class="research-filters" id="research-filters">
        <div class="research-filters__group">
          <span class="research-filters__label">Source</span>
          <button class="research-filter-btn active" data-filter-type="source" data-filter-value="all">All</button>
          {sourceTypes.map((type) => (
            <button class="research-filter-btn" data-filter-type="source" data-filter-value={type}>
              {sourceTypeLabels[type] || type}
            </button>
          ))}
        </div>
        <div class="research-filters__group">
          <span class="research-filters__label">Topic</span>
          <button class="research-filter-btn active" data-filter-type="tag" data-filter-value="all">All</button>
          {allTags.map((tag) => (
            <button class="research-filter-btn" data-filter-type="tag" data-filter-value={tag}>
              {tag}
            </button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Research Grid -->
  <section class="research-grid-section">
    <div class="container">
      <div class="research-grid" id="research-grid">
        {researchData.briefs.map((brief) => (
          <article
            class="research-card"
            data-source={brief.sourceType}
            data-tags={brief.tags.join(',')}
          >
            <p class="research-card__source">{sourceTypeLabels[brief.sourceType] || brief.sourceType}</p>
            <h3 class="research-card__title">{brief.title}</h3>
            <p class="research-card__abstract">{brief.abstract}</p>
            <div class="research-card__meta">
              <span class="research-card__date">{brief.publishedDate}</span>
              <div class="research-card__tags">
                {brief.tags.map((tag) => (
                  <span class="research-card__tag">{tag}</span>
                ))}
              </div>
            </div>
            {brief.externalURL ? (
              <a href={brief.externalURL} class="btn-tertiary" target="_blank" rel="noopener">Read →</a>
            ) : (
              <span class="research-card__pending">Full text in preparation</span>
            )}
          </article>
        ))}
      </div>
      <p class="research-empty" id="research-empty">
        No briefs match the selected filters.
      </p>
    </div>
  </section>

  <Fragment slot="scripts">
    <script>
      // Client-side filtering for research briefs
      const filterBtns = document.querySelectorAll('.research-filter-btn');
      const cards = document.querySelectorAll('.research-card');
      const emptyMsg = document.getElementById('research-empty');

      let activeSource = 'all';
      let activeTag = 'all';

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const type = btn.getAttribute('data-filter-type')!;
          const value = btn.getAttribute('data-filter-value')!;

          // Update active state within group
          document.querySelectorAll(`.research-filter-btn[data-filter-type="${type}"]`).forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          if (type === 'source') activeSource = value;
          if (type === 'tag') activeTag = value;

          let visibleCount = 0;
          cards.forEach(card => {
            const cardSource = card.getAttribute('data-source');
            const cardTags = card.getAttribute('data-tags')?.split(',') || [];

            const matchSource = activeSource === 'all' || cardSource === activeSource;
            const matchTag = activeTag === 'all' || cardTags.includes(activeTag);

            if (matchSource && matchTag) {
              (card as HTMLElement).style.display = '';
              visibleCount++;
            } else {
              (card as HTMLElement).style.display = 'none';
            }
          });

          if (emptyMsg) {
            emptyMsg.style.display = visibleCount === 0 ? '' : 'none';
          }
        });
      });
    </script>
  </Fragment>
</BaseLayout>

<style>
  /* Filter Bar */
  .research-filter-section {
    padding: var(--space-xl) 0 4rem;
  }
  .research-filters {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .research-filters__group {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
  }
  .research-filters__label {
    font-family: var(--font-sans);
    font-size: var(--label-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
    margin-right: var(--space-sm);
    min-width: 4rem;
  }
  .research-filter-btn {
    font-family: var(--font-sans);
    font-size: var(--label-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--space-sm) 0.875rem;
    border: var(--border-hairline) solid var(--outline-variant);
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--secondary);
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  .research-filter-btn:hover {
    border-color: var(--primary);
    color: var(--primary);
  }
  .research-filter-btn.active {
    background-color: var(--primary);
    color: var(--on-primary);
    border-color: var(--primary);
  }

  /* Research Grid */
  .research-grid-section {
    padding: 0 0 8rem;
  }
  .research-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-xl);
  }
  .research-card {
    background-color: var(--surface-container-lowest);
    border-radius: var(--radius-sm);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    border: var(--border-hairline) solid rgba(var(--outline-variant-rgb), 0.2);
  }
  .research-card__source {
    font-family: var(--font-sans);
    font-size: var(--label-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--secondary);
  }
  .research-card__title {
    font-family: var(--font-serif);
    font-size: var(--title-lg);
    color: var(--primary);
    line-height: 1.3;
  }
  .research-card__abstract {
    font-family: var(--font-sans);
    font-size: var(--body-md);
    color: var(--on-surface-variant);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .research-card__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-top: auto;
  }
  .research-card__date {
    font-family: var(--font-sans);
    font-size: var(--label-sm);
    color: var(--secondary);
  }
  .research-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .research-card__tag {
    font-family: var(--font-sans);
    font-size: var(--font-size-mini);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--space-xs) var(--space-sm);
    background-color: var(--surface-container-low);
    color: var(--secondary);
    border-radius: var(--radius-sm);
  }
  .research-card__pending {
    font-family: var(--font-sans);
    font-size: var(--label-sm);
    color: var(--secondary);
    font-style: italic;
  }
  .research-empty {
    font-family: var(--font-sans);
    font-size: var(--body-lg);
    color: var(--secondary);
    text-align: center;
    padding: 4rem 0;
    display: none;
  }

  @media (max-width: 768px) {
    .research-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
