{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    }
  },
  "additionalProperties": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string"
      },
      "role": {
        "type": "string"
      },
      "bio": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "photo": {
        "type": "string"
      },
      "group": {
        "type": "string",
        "enum": [
          "leadership",
          "departmentHeads",
          "secretariat"
        ]
      },
      "linkedin": {
        "type": "string",
        "format": "uri"
      }
    },
    "required": [
      "name",
      "role",
      "bio",
      "photo",
      "group"
    ]
  }
}